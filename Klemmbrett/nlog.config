<?xml version="1.0" encoding="utf-8"?>
<!-- Kroste-Standard: So viel wie möglich loggen. Datei = Trace aufwärts (alles),
     Konsole = Info aufwärts. Secrets werden über den masked-Layout-Renderer
     maskiert (MaskingLayoutRenderer im Projekt registrieren, siehe SKILL.md). -->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="logs/nlog-internal.log">

  <targets>
    <target xsi:type="File" name="file"
            fileName="logs/Klemmbrett.log"
            archiveFileName="logs/archive/Klemmbrett.{#}.log"
            archiveEvery="Day"
            maxArchiveFiles="14"
            layout="${longdate}|${level:uppercase=true}|${logger}|${masked:inner=${message}}${onexception:inner=|${exception:format=tostring}}" />

    <target xsi:type="ColoredConsole" name="console"
            layout="${time}|${level:uppercase=true}|${logger:shortName=true}|${masked:inner=${message}}${onexception:inner=|${exception:format=message}}" />
  </targets>

  <rules>
    <!-- Alles in die Datei — Trace ist Absicht, nicht Versehen -->
    <logger name="*" minlevel="Trace" writeTo="file" />
    <logger name="*" minlevel="Info" writeTo="console" />
  </rules>
</nlog>
