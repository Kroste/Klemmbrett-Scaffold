<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Klemmbrett"
             x:Class="Klemmbrett.App"
             RequestedThemeVariant="Dark">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <!-- Kroste-Palette (etabliert in Amtsschimmel/Checkmk Cockpit) -->
        <SolidColorBrush x:Key="KrosteBackgroundBrush" Color="#1A1D21" />
        <SolidColorBrush x:Key="KrosteTitleBarBrush" Color="#14161A" />
        <SolidColorBrush x:Key="KrosteSurfaceBrush" Color="#22262B" />
        <SolidColorBrush x:Key="KrosteAccentBrush" Color="#123E6B" />
        <SolidColorBrush x:Key="KrosteGoldBrush" Color="#E0B14C" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <!-- Fensterbuttons der Titelleiste -->
        <Style Selector="Button.chrome">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.chrome:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2A2E33" />
        </Style>
        <Style Selector="Button.chrome.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#C42B1C" />
        </Style>
        <!-- Anheften-Knopf je Listeneintrag -->
        <Style Selector="ToggleButton.pin">
            <Setter Property="Content" Value="📌" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip.Tip" Value="Anheften (bleibt oben, läuft nicht ab)" />
        </Style>
        <Style Selector="ToggleButton.pin:checked">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ToggleButton.pin:pointerover">
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <!-- Löschen-Knopf je Listeneintrag -->
        <Style Selector="Button.delete">
            <Setter Property="Content" Value="🗑" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip.Tip" Value="Diesen Eintrag löschen (Entf)" />
        </Style>
        <Style Selector="Button.delete:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <!-- Aufdecken-Knopf für maskierte Passwörter -->
        <Style Selector="ToggleButton.reveal">
            <Setter Property="Content" Value="👁" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip.Tip" Value="Passwort anzeigen / verbergen" />
        </Style>
        <Style Selector="ToggleButton.reveal:checked">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ToggleButton.reveal:pointerover">
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <!-- Kommentar-Knopf je Listeneintrag -->
        <Style Selector="ToggleButton.comment">
            <Setter Property="Content" Value="💬" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip.Tip" Value="Kommentar hinzufügen / bearbeiten" />
        </Style>
        <Style Selector="ToggleButton.comment:checked">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ToggleButton.comment:pointerover">
            <Setter Property="Opacity" Value="0.8" />
        </Style>
    </Application.Styles>
</Application>
