<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="using:Avalonia.Controls.Chrome"
             x:Class="Klemmbrett.Controls.TitleBar"
             Height="36">
    <!-- ElementRole ist der Avalonia-12-Mechanismus für Custom-Chrome-Hit-Testing:
         TitleBar = OS übernimmt Drag + Doppelklick-Maximieren nativ (HTCAPTION).
         Buttons = Rolle "User" (HTCLIENT): Klicks laufen als normale Client-
         Eingabe direkt zu den Avalonia-Buttons. NICHT MinimizeButton/
         MaximizeButton/CloseButton verwenden — diese Rollen leiten über den
         Non-Client-Pfad (HTMINBUTTON &amp; Co.), wo DWM die Klicks schlucken
         kann → tote Buttons. Ohne Rollen schluckt die Caption-Zone alles. -->
    <Border x:Name="Bar"
            Background="{DynamicResource KrosteTitleBarBrush}"
            chrome:WindowDecorationProperties.ElementRole="TitleBar">
        <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock x:Name="TitleText"
                       Margin="12,0" VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource KrosteGoldBrush}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="MinButton" Classes="chrome" Content="—"
                        chrome:WindowDecorationProperties.ElementRole="User" />
                <Button x:Name="MaxButton" Classes="chrome" Content="❐"
                        chrome:WindowDecorationProperties.ElementRole="User" />
                <Button x:Name="CloseButton" Classes="chrome close" Content="✕"
                        chrome:WindowDecorationProperties.ElementRole="User" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
