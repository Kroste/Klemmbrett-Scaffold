<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Klemmbrett.Views"
        xmlns:controls="using:Klemmbrett.Controls"
        x:Class="Klemmbrett.Views.AboutWindow"
        Width="380" Height="340"
        Title="Über Klemmbrett"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource KrosteBackgroundBrush}">
    <DockPanel>
        <controls:TitleBar DockPanel.Dock="Top" Title="Über Klemmbrett" />
        <StackPanel Margin="24,18" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="Klemmbrett" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource KrosteGoldBrush}" />
            <TextBlock x:Name="VersionText" Foreground="#AAAAAA" />
            <TextBlock Text="Zwischenablage-Verlauf für Text und Bilder."
                       TextWrapping="Wrap" Foreground="#CCCCCC" />

            <TextBlock x:Name="UpdateStatus" Foreground="{DynamicResource KrosteGoldBrush}"
                       TextWrapping="Wrap" Margin="0,6,0,0" IsVisible="False" />

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                <Button x:Name="CheckUpdateButton" Content="Auf Updates prüfen"
                        Click="OnCheckUpdateClick" />
                <Button Content="GitHub" Click="OnGithubClick" />
                <Button Content="☕" ToolTip.Tip="Buy me a coffee" Click="OnBmcClick" />
            </StackPanel>
            <Button Content="Schließen" HorizontalAlignment="Right" Click="OnCloseClick" />
        </StackPanel>
    </DockPanel>
</views:ChromeWindow>
