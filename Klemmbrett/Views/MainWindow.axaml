<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Klemmbrett.ViewModels"
        xmlns:views="using:Klemmbrett.Views"
        xmlns:controls="using:Klemmbrett.Controls"
        xmlns:m="using:Klemmbrett.Models"
        x:Class="Klemmbrett.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Klemmbrett"
        Width="480" Height="640"
        Background="{DynamicResource KrosteBackgroundBrush}">
    <DockPanel>
        <controls:TitleBar DockPanel.Dock="Top" Title="Klemmbrett" />

        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="12,10,12,0">
            <TextBox x:Name="SearchBox" Text="{Binding SearchText}" Watermark="Suchen… (Strg+F)" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Zeitraum:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Days}" SelectedItem="{Binding SelectedDay}" MinWidth="170" />
            </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="12,8,12,12">
            <Button Content="🧹 Historie leeren" Command="{Binding ClearHistoryCommand}" />
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
        </StackPanel>

        <ListBox Margin="12,12,12,0" ItemsSource="{Binding Entries}"
                 SelectedItem="{Binding SelectedEntry}"
                 DoubleTapped="OnEntryDoubleTapped"
                 Background="{DynamicResource KrosteSurfaceBrush}">
            <ListBox.DataTemplates>
                <DataTemplate DataType="m:TextClipboardEntry">
                    <Grid ColumnDefinitions="Auto,*">
                        <ToggleButton Grid.Column="0" Classes="pin"
                                      IsChecked="{Binding IsPinned, Mode=OneWay}"
                                      Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).TogglePinCommand}"
                                      CommandParameter="{Binding}" />
                        <TextBlock Grid.Column="1" Text="{Binding Preview}"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
                <DataTemplate DataType="m:ImageClipboardEntry">
                    <Grid ColumnDefinitions="Auto,Auto,*">
                        <ToggleButton Grid.Column="0" Classes="pin"
                                      IsChecked="{Binding IsPinned, Mode=OneWay}"
                                      Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).TogglePinCommand}"
                                      CommandParameter="{Binding}" />
                        <Border Grid.Column="1" Background="{DynamicResource KrosteBackgroundBrush}"
                                CornerRadius="4" Padding="2" Margin="0,0,10,0">
                            <Image Source="{Binding Bitmap}" MaxWidth="96" MaxHeight="64" Stretch="Uniform" />
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding Info}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource KrosteGoldBrush}" />
                    </Grid>
                </DataTemplate>
            </ListBox.DataTemplates>
        </ListBox>
    </DockPanel>
</views:ChromeWindow>
